# Copie para backend/.env (o .gitignore ignora ficheiros .env).
# Com ./run_local.sh, as variáveis deste ficheiro são carregadas automaticamente.
# Se iniciar o uvicorn à mão: exporte antes ou: (cd backend && set -a && . .env && set +a && uvicorn ...)
#
# PostgreSQL (Supabase, Railway, etc.):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
#
# Desenvolvimento local sem Postgres: omita DATABASE_URL para usar SQLite (./plans.db).
#
# DATABASE_URL=
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
